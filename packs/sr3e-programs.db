{"_id":"sr3e-prog-0017","name":"Mirrors","type":"program","img":"icons/svg/net.svg","system":{"name":"Mirrors","type":"Program","category":"Defensive","rating":0,"sizeMp":0,"multiplier":4,"degradable":true,"description":"<p>Decreases user's TN by rating while being scrutinized by System Sweep or Authenticate ability.</p><p><em>Works by spamming fake token icons (falsified records, timestamps).</em></p>","associatedPrompt":"Defense vs System Sweep / Authenticate","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0018","name":"Read/Write","type":"program","img":"icons/svg/net.svg","system":{"name":"Read/Write","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":2,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing any Datafile prompts.</p>","associatedPrompt":"Access Datafile, Duplicate/Download Datafile, Edit/Upload Datafile","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0019","name":"Redirect","type":"program","img":"icons/svg/net.svg","system":{"name":"Redirect","type":"Program","category":"Defensive","rating":0,"sizeMp":0,"multiplier":5,"degradable":true,"description":"<p>Increases target number by its rating for enemy icons attempting to target the user with the Trace Signal prompt.</p>","associatedPrompt":"Defense vs Trace Signal","effect":"TN Increase (Enemy)"}}
{"_id":"sr3e-prog-0020","name":"Saboteur","type":"program","img":"icons/svg/net.svg","system":{"name":"Saboteur","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":4,"degradable":false,"description":"<p>Databombs an unprotected target up to the rating of the utility when using Configure Protections prompt.</p><p><strong>Protection Type:</strong> Databomb</p>","associatedPrompt":"Configure Protections","effect":"Apply Protection"}}
{"_id":"sr3e-prog-0021","name":"Shield","type":"program","img":"icons/svg/net.svg","system":{"name":"Shield","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":3,"degradable":true,"description":"<p>Mitigates special IC attacks targeting hardware (MPCP, Memory, utility slots). Degrade Shield instead of hardware.</p><p><strong>Protects Against:</strong> Corruption, Corrupt and Burn, Erosion</p>","associatedPrompt":"Defense vs IC Special Abilities","effect":"Hardware Protection"}}
{"_id":"sr3e-prog-0022","name":"Signal Booster","type":"program","img":"icons/svg/net.svg","system":{"name":"Signal Booster","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":1,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing the Send Transmission prompt.</p>","associatedPrompt":"Send Transmission","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0023","name":"Sleaze","type":"program","img":"icons/svg/net.svg","system":{"name":"Sleaze","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":4,"degradable":true,"description":"<p>Allows user to harmlessly pass-through (ignore) any Matrix barrier with rating equal-to or lower than program's current rating.</p><p><em>Degrades by 1 point after each use.</em></p>","associatedPrompt":"Movement","effect":"Barrier Bypass"}}
{"_id":"sr3e-prog-0024","name":"Slow","type":"program","img":"icons/svg/net.svg","system":{"name":"Slow","type":"Program","category":"Combat","rating":0,"sizeMp":0,"multiplier":4,"degradable":false,"description":"<p>Specialized combat program that reduces target icon's Initiative by 3 points per net success instead of staging damage.</p><p><em>Icon crashes if Initiative reduced to 0 within a single turn.</em></p>","associatedPrompt":"Attack an Icon","effect":"Initiative Reduction"}}
{"_id":"sr3e-prog-0025","name":"Smoke Screen","type":"program","img":"icons/svg/net.svg","system":{"name":"Smoke Screen","type":"Program","category":"Defensive","rating":0,"sizeMp":0,"multiplier":4,"degradable":true,"description":"<p>Increases target number by its current rating for enemy icons attempting to target the user with Search and Render.</p>","associatedPrompt":"Defense vs Search and Render","effect":"TN Increase (Enemy)"}}
{"_id":"sr3e-prog-0026","name":"Snoop","type":"program","img":"icons/svg/net.svg","system":{"name":"Snoop","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":3,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing Tap Datastream or Spoof Datastream prompts.</p>","associatedPrompt":"Tap Datastream, Spoof Datastream","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0027","name":"Suppression","type":"program","img":"icons/svg/net.svg","system":{"name":"Suppression","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":5,"degradable":true,"description":"<p>May be used when crashing an icon. Instead of accruing Overwatch, degrade Suppression to suppress the crash.</p>","associatedPrompt":"Attack an Icon (On Crash)","effect":"Overwatch Prevention"}}
{"_id":"sr3e-prog-0028","name":"Dewormer","type":"program","img":"icons/svg/net.svg","system":{"name":"Dewormer","type":"Protocol","category":"","rating":0,"sizeMp":0,"multiplier":3,"degradable":false,"description":"<p>Purges a cyberdeck or Matrix enabled device of an Infiltrating IC Agent. Takes hours equal to rating of infiltrator. Can only purge infiltrators up to its rating.</p><p><strong>Function:</strong> Anti-Infiltration</p>","associatedPrompt":"","effect":"Purge IC"}}
{"_id":"sr3e-prog-0029","name":"Nexus","type":"program","img":"icons/svg/net.svg","system":{"name":"Nexus","type":"Protocol","category":"","rating":0,"sizeMp":0,"multiplier":4,"degradable":false,"description":"<p>Grants priority access to Denver Data Haven. Decreases TN by rating while conducting Matrix legwork or using Etiquette: Matrix.</p><p><strong>Function:</strong> Legwork</p><p><strong>Skill:</strong> Etiquette: Matrix</p>","associatedPrompt":"","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0030","name":"Shadownet","type":"program","img":"icons/svg/net.svg","system":{"name":"Shadownet","type":"Protocol","category":"","rating":0,"sizeMp":0,"multiplier":5,"degradable":false,"description":"<p>Grants passcode access to Shadownet LTG. Delays Convergence trace information and physical security response by minutes equal to rating.</p><p><strong>Function:</strong> Access + Safety</p>","associatedPrompt":"","effect":"Delay Convergence"}}
