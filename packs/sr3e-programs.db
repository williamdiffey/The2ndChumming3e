{"_id":"sr3e-prog-0014","name":"Kill Switch","type":"program","img":"icons/svg/net.svg","system":{"name":"Kill Switch","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":5,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing the Crack Protections prompt to disarm a Databombed target.</p><p><em>Failure results in self-destruction of target icon.</em></p>","associatedPrompt":"Crack Protections (Databomb)","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0015","name":"Lock-On","type":"program","img":"icons/svg/net.svg","system":{"name":"Lock-On","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":6,"degradable":false,"description":"<p>Decreases user's TN by rating while using Trace Signal. Even one success establishes a Link-Lock.</p>","associatedPrompt":"Trace Signal","effect":"TN Reduction + Link-Lock"}}
