{"_id":"sr3e-prog-0001","name":"Passcode","type":"program","img":"icons/svg/net.svg","system":{"name":"Passcode","type":"Passcode","category":"","rating":1,"sizeMp":0,"multiplier":1,"degradable":false,"description":"<p>Legitimate access credentials. Allows automatic marking of specified nodes without Hacking roll or Overwatch accrual.</p><p><em>Rating indicates breadth/restrictiveness of access. Can be as narrow as a single datafile or as broad as an entire host.</em></p><p><strong>Function:</strong> Access</p>","associatedPrompt":"","effect":""}}
{"_id":"sr3e-prog-0002","name":"Analyze","type":"program","img":"icons/svg/net.svg","system":{"name":"Analyze","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":3,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing the Search and Render prompt.</p>","associatedPrompt":"Search and Render","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0003","name":"Armor","type":"program","img":"icons/svg/net.svg","system":{"name":"Armor","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":3,"degradable":true,"description":"<p>May be used to soak Overload Damage. Instead of applying damage to Matrix Condition Monitor, degrade Armor on a point-for-point basis.</p><p><strong>Soak Type:</strong> Overload</p>","associatedPrompt":"Attack an Icon (Defense)","effect":"Damage Soak"}}
{"_id":"sr3e-prog-0004","name":"Attack","type":"program","img":"icons/svg/net.svg","system":{"name":"Attack","type":"Program","category":"Combat","rating":0,"sizeMp":0,"multiplier":0,"degradable":false,"description":"<p>Operational combat program designed to inflict damage upon other icons.</p><p><strong>Variants:</strong></p><ul><li>Light Overload (×2)</li><li>Moderate Overload (×3)</li><li>Severe Overload (×4)</li><li>Deadly Overload (×5)</li><li>Nosebleed — Light Biofeedback (×5)</li><li>Blackout — Moderate Biofeedback (×10)</li><li>Killjoy — Severe Biofeedback (×15)</li><li>Black Hammer — Deadly Biofeedback (×20)</li></ul>","associatedPrompt":"Attack an Icon","effect":"Damage"}}
{"_id":"sr3e-prog-0005","name":"Baby Monitor","type":"program","img":"icons/svg/net.svg","system":{"name":"Baby Monitor","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":3,"degradable":true,"description":"<p>Allows user to get a peek at current Overwatch level. GM relays boxes accrued in terms of wound levels.</p>","associatedPrompt":"Scrub Datastream","effect":"Information"}}
{"_id":"sr3e-prog-0006","name":"Biofeedback Filtering","type":"program","img":"icons/svg/net.svg","system":{"name":"Biofeedback Filtering","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":3,"degradable":true,"description":"<p>May be used to soak Biofeedback Damage on a point-for-point basis.</p><p><strong>Soak Type:</strong> Biofeedback</p>","associatedPrompt":"Attack an Icon (Defense)","effect":"Damage Soak"}}
{"_id":"sr3e-prog-0007","name":"Browse","type":"program","img":"icons/svg/net.svg","system":{"name":"Browse","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":1,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing any Index prompts.</p>","associatedPrompt":"Index Data Store, Index Subscribed Devices, Index Users and Scheduling","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0008","name":"Decrypt","type":"program","img":"icons/svg/net.svg","system":{"name":"Decrypt","type":"Program","category":"Offensive","rating":0,"sizeMp":0,"multiplier":4,"degradable":false,"description":"<p>Decreases the user's target number by its rating while utilizing the Crack Protections prompt to decode an Encrypted target.</p><p><em>Base Decrypt time = Encryption Rating x 10 minutes.</em></p>","associatedPrompt":"Crack Protections (Encryption)","effect":"TN Reduction"}}
{"_id":"sr3e-prog-0009","name":"Encrypt","type":"program","img":"icons/svg/net.svg","system":{"name":"Encrypt","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":3,"degradable":false,"description":"<p>Encrypts a target up to the rating of the utility when using Configure Protections prompt.</p><p><strong>Protection Type:</strong> Encryption</p>","associatedPrompt":"Configure Protections","effect":"Apply Protection"}}
{"_id":"sr3e-prog-0010","name":"Evasion","type":"program","img":"icons/svg/net.svg","system":{"name":"Evasion","type":"Program","category":"Operational","rating":0,"sizeMp":0,"multiplier":4,"degradable":true,"description":"<p>Allows user to utilize Toggle Visibility prompt to become Hidden, even while currently Link-Locked.</p>","associatedPrompt":"Toggle Visibility","effect":"Stealth"}}
